                                                        <div>
                                                            <button disabled="{!v.EditselectedStep != 'step1' ? '' : 'disabled'}" class="slds-button slds-button--neutral" onclick="{!c.handleEditPrev}">Back</button>  
                                                            <aura:if isTrue="{!v.EditselectedStep != 'step6'}">
                                                                <button class="slds-button slds-button--brand" onclick="{!c.handleEditNext}">Next</button>
                                                            </aura:if>
                                                            <aura:if isTrue="{!v.EditselectedStep == 'step6'}">   
