                                                                <aura:iteration items="{!v.OrderStringFields}" var="per">
                                                                    <option value="{!per}" text="{!per}" /> 
                                                                </aura:iteration>
                                                            </lightning:select>
                                                        </th>
                                                    </tr>
                                                    
                                                  <!--  <tr class="slds-hint-parent">
                                                        <th data-label="Shopify" scope="row">
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control">
                                                                    <div class="slds-combobox_container ">
                                                                        <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                            {!v.Last_Order_id}
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </th>
                                                        <th data-label="Salesforce" scope="row">
                                                            <lightning:select aura:id="SelectedOrderField" class="" name="select1" label="Choose Field" onchange="{!c.Order_Last_Order_id}">
                                                                <option value="None" text="None" /> 
                                                                <aura:iteration items="{!v.OrderStringFields}" var="per">
                                                                    <option value="{!per}" text="{!per}" /> 
                                                                </aura:iteration>
                                                            </lightning:select>
                                                        </th>
                                                    </tr> -->
                                                    
                                                    <tr class="slds-hint-parent">
                                                        <th data-label="Shopify" scope="row">
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control">
                                                                    <div class="slds-combobox_container ">
                                                                        <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                            {!v.Order_Name}
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </th>
                                                        <th data-label="Salesforce" scope="row">
                                                            <lightning:select aura:id="SelectedOrderField" class="" name="select1" label="Choose Field" onchange="{!c.Order_Order_Number}">
                                                                <option value="Order_Name" text="Order_Name" />   
                                                                <!--   <aura:iteration items="{!v.OrderStringFields}" var="per">
                                                                                        <option value="{!per}" text="{!per}" /> 
                                                                                    </aura:iteration> -->
                                                            </lightning:select>
                                                        </th>
                                                    </tr>
                                                    
                                                    <tr class="slds-hint-parent">
                                                        <th data-label="Shopify" scope="row">
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control">
                                                                    <div class="slds-combobox_container ">
                                                                        <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                            {!v.Orders_Count}
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </th>
                                                        <th data-label="Salesforce" scope="row">
                                                            <lightning:select aura:id="SelectedOrderField" class="" name="select1" label="Choose Field" onchange="{!c.Orders_Count}">
                                                                <option value="None" text="None" /> 
                                                                <aura:iteration items="{!v.OrderStringFields}" var="per">
                                                                    <option value="{!per}" text="{!per}" /> 
                                                                </aura:iteration>
                                                            </lightning:select>
                                                        </th>
                                                    </tr>
                                                    
                                                    <tr class="slds-hint-parent">
                                                        <th data-label="Shopify" scope="row">
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control">
                                                                    <div class="slds-combobox_container ">
                                                                        <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                            Order_ID
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </th>  
                                                        <th data-label="Salesforce" scope="row">
                                                            <lightning:select aura:id="SelectedOrderField" class="" name="select1" label="Choose Field" onchange="">
                                                                <option value="Order_ID" text="Shopify_Order_ID" /> 
                                                                <!--    <aura:iteration items="{!v.OrderStringFields}" var="per">
                                                                                        <option value="{!per}" text="{!per}" /> 
                                                                                    </aura:iteration> -->
                                                            </lightning:select>
                                                        </th>
                                                    </tr>
                                                    
                                                    <tr class="slds-hint-parent">
                                                        <th data-label="Shopify" scope="row">
                                                            <div class="slds-form-element">
                                                                <div class="slds-form-element__control">
                                                                    <div class="slds-combobox_container ">
                                                                        <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                            {!v.Total_Price}
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </th>
                                                        <th data-label="Salesforce" scope="row">
                                                            <lightning:select aura:id="OrderField" class="" name="select1" label="Choose Field" onchange="{!c.Order_Total_Price}">
                                                                <option value="None" text="None" /> 
                                                                <aura:iteration items="{!v.OrderStringFields}" var="per">
                                                                    <option value="{!per}" text="{!per}" /> 
                                                                </aura:iteration>
                                                            </lightning:select>
                                                        </th>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>                 
                                    
                                    
                                    <div>
                                        <button disabled="{!v.selectedStep != 'step1' ? '' : 'disabled'}" class="slds-button slds-button--neutral" onclick="{!c.handlePrev}">Back</button>  
                                        <aura:if isTrue="{!v.selectedStep != 'step6'}">
                                            <button class="slds-button slds-button--brand" onclick="{!c.handleNext}">Next</button>
                                        </aura:if>
                                        <aura:if isTrue="{!v.selectedStep == 'step6'}">   
                                            <lightning:button label="Save" title="Save" onclick="{! c.handleSaveEditShopify }"/>  
                                        </aura:if>
                                    </div>
                                    <br/>
                                </div>
                            </div>
                        </div>
                    </section>
                    <div class="slds-backdrop slds-backdrop_open"></div>
                    <!--###### MODAL BOX Part END Here ######-->
                </aura:if>
                
            </div>
            <br/>
            <article class="slds-card">
                <div class="slds-p-horizontal_x-small">
                    
                    <div class="slds-float_right">
                        <ui:inputSelect aura:id="pageSize" label="Show Entries " change="{!c.onSelectChange}">
                            <ui:inputSelectOption text="5" label="5" value="true"/>
                            <ui:inputSelectOption text="10" label="10" />
                            <ui:inputSelectOption text="15" label="15"/>
                            <ui:inputSelectOption text="20" label="20"/>
                        </ui:inputSelect>
                    </div>
                    <br/>
                    <div class="slds-form-element__control slds-input-has-icon slds-input-has-icon_left">
                        <lightning:icon class="slds-icon slds-input__icon slds-input__icon_left slds-icon-text-default" iconName="utility:search" size="x-small" alternativeText="Search address"/>
                        <lightning:input 
                                         value="{!v.searchKeyword}"
                                         placeholder="Search Shop "
                                         label="Name"  
                                         type="text"  onkeyup="{!c.SearchShop}"
                                         variant="label-hidden"/>
                    </div>
                </div>
                <br/>
                <div class="slds-scrollable_x">
                    <table class="slds-table slds-table_bordered slds-table_cell-buffer slds-table_striped" >
                        <thead>
                            <tr class="slds-text-title_caps">
                                <th scope="col">
                                    <strong><div class="slds-truncate" title="S.NO">S.NO</div></strong>
                                </th>
                                <th scope="col">
                                    <strong><div class="slds-truncate" title="SHOP NAME">SHOP NAME</div></strong>
                                </th>
                                <th scope="col">
                                    <strong><div class="slds-truncate" title="DEFAULT SHOP">CHOOSE SHOP</div></strong>
                                </th> 
                                <th scope="col">
                                    <strong><div class="slds-truncate" title="ACTION">ACTION</div></strong>
                                </th> 
                            </tr>
                        </thead>
                        
                        <tbody >
                            <aura:iteration items="{!v.Shoplist}" var="pr" indexVar="idx" > 
                                <tr>
                                    <th scope="row" data-label="S.NO">
                                        <div class="slds-truncate" title="">{!idx+1}</div>
                                    </th>
                                    <th scope="row" data-label="SHOP NAME">
                                        <div class="slds-truncate" title="{!pr.TechnologyMind__Shop_Url__c}"><a href="{!pr.Name}" target="_blank">{!pr.Name}</a></div>
                                        
                                        <!-- <div class="slds-truncate" title="{!pr.TechnologyMind__Shop_Url__c}">{!pr.Name}</div> -->
                                    </th>
                                    <th scope="row" data-label="CHOOSE SHOP">
                                        <div id ="divtoggle" class="slds-truncate" data-Id="{!idx}" data-value ="{!pr.Id}" >
                                            <lightning:input aura:id="toggleid" type="toggle" label="" name="input2" checked="{!pr.TechnologyMind__Default_Shop__c}" onchange="{!c.toggleDefaultShop}" />
                                        </div>
                                    </th>    
                                    <th scope="row">
                                        
                                        
                                        <div id ="EditButton" class="slds-truncate" data-Id="" data-value ="{!pr.Id}" >
                                            <lightning:buttonIcon  class="" alternativeText="edit" iconClass="" variant="bare" type="button" iconName="utility:edit" size="large" onclick="{!c.editModel}"></lightning:buttonIcon>
                                            <lightning:buttonIcon class="" alternativeText="delete" iconClass="" variant="bare" type="button" iconName="utility:delete" size="large" onclick="{!c.deleteshop}"></lightning:buttonIcon> 
				                        
                                        </div>
                                  
                                    </th>
                                    <aura:if isTrue="{!v.isEdit}">
                                        
                                        <!--###### MODAL BOX Start######--> 
                                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                            <div class="slds-modal__container" >
                                                <!-- ###### MODAL BOX HEADER Start ######-->
                                                <header class="slds-modal__header">
                                                    <lightning:buttonIcon iconName="utility:close"
                                                                          onclick="{! c.closeModel }"
                                                                          alternativeText="close"
                                                                          variant="bare-inverse"
                                                                          class="slds-modal__close"/>
                                                    <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate"><b>Configuration</b></h2>
                                                </header>
                                                <!--###### MODAL BOX BODY Part Start######-->
                                                <div class="slds-card">
                                                    <div class="slds-m-around_xx-large">
                                                        <c:MessageComponent type="{!v.messageType}" message="{!v.message}" class="{!v.messageshow}"/>
                                                        <lightning:progressIndicator currentStep="{!v.EditselectedStep}" type="path">
                                                            
                                                            <lightning:progressStep label="General" value="step1" onclick="{!c.EditselectStep1}"/>
                                                            <lightning:progressStep label="Object Setting" value="step2" onclick="{!c.EditselectStep2}"/>
                                                            <lightning:progressStep label="Customer Filed Mapping" value="step4" onclick="{!c.EditselectStep4}"/>
                                                            <lightning:progressStep label="Product Filed Mapping" value="step5" onclick="{!c.EditselectStep5}"/>
                                                            <lightning:progressStep label="Order Filed Mapping" value="step6" onclick="{!c.EditselectStep6}"/>
                                                            
                                                        </lightning:progressIndicator>
                                                        <div class="slds-p-around--medium ">
                                                            <div class="{!v.EditselectedStep == 'step1' ? 'slds-show' : 'slds-hide'}">
                                                                <div class="slds-scrollable_y" > 
                                                                    <div class="inputdiv">                         
                                                                        <lightning:input aura:id="EditURL" name="Name" label="Shopify Shop URL" value="{!v.EditShopURL}" required="true"/>
                                                                        <!--  <lightning:input name="Salesforce Site URL" label="Salesforce Site URL" value="{!v.simpleNewShopify.Salesforce_Site_URL__c}" required="true"/> -->
                                                                        <lightning:input aura:id="EditAccessToken" name="access Token" label="Shopify Access Token" value="{!v.EditAccessToken}" required="true"/>
                                                                        <!-- <lightning:combobox label="" options="{!v.options}" placeholder="Salesforce Pricebook " dropdownAlignment="left" variant="standard"></lightning:combobox> -->
                                                                        <lightning:input aura:id="EditAppPassword" type="password" name="Shopify App Password" label="Shopify App Password" value="{!v.EditPassword}" required="true"/>
                                                                        <br/>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="{!v.EditselectedStep == 'step2' ? 'slds-show' : 'slds-hide'}">
                                                                <div class="slds-scrollable_y" > 
                                                                    <p><b>Step 2</b></p>
                                                                    <table cellspacing="0" rules="all" border="1" id="Table1" style="border-collapse: collapse;">
                                                                        <tr>
                                                                            <th class="slds-text-heading_medium slds-p-around_xx-small ABD" ><center>Shopify</center></th>
                                                                            <th class="slds-text-heading_medium slds-p-around_xx-small ABE" ><center>Salesforce</center></th>
                                                                        </tr>
                                                                        <tr>
                                                                            <td><center>Product</center></td>
                                                                            <!--xx-small, x-small, small, medium, or large  -->
                                                                            <td><div class="slds-p-around_x-small slds-text-align_center"> <lightning:icon iconName="action:approval" alternativeText="Approved" size="xx-small" /> &nbsp;Mapped as Product</div></td>
                                                                        </tr>
                                                                        <tr>
                                                                            <td><center>Customer</center></td>
                                                                            <td><div class="slds-p-around_x-small slds-text-align_center"> <lightning:icon iconName="action:approval" alternativeText="Approved" size="xx-small" /> &nbsp;Mapped as Account</div></td>
                                                                        </tr>
                                                                        <tr>
                                                                            <td><center>Order</center></td>
                                                                            <td><div class="slds-p-around_x-small slds-text-align_center"> <lightning:icon iconName="action:approval" alternativeText="Approved" size="xx-small" /> &nbsp;Mapped as ShopifyOrders</div></td>
                                                                        </tr>
                                                                    </table>
                                                                    <br />
                                                                </div>
                                                            </div>
                                                            <div class="{!v.EditselectedStep == 'step4' ? 'slds-show' : 'slds-hide'}">
                                                                <p><b>Step 3</b></p>
                                                                <div class="slds-scrollable_y" >
                                                                    <h1><center><b>Customer Field Mapping</b></center></h1>
                                                                    <table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_col-bordered ABF" >
                                                                        <thead>
                                                                            <tr class="slds-line-height_reset">
                                                                                <th class="" scope="col">
                                                                                    <div class="slds-truncate" title="Shopify" >Shopify</div>
                                                                                </th>
                                                                                <th class="" scope="col">
                                                                                    <div class="slds-truncate" title="Salesforce">Salesforce</div>
                                                                                </th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                            <tr class="slds-hint-parent">
                                                                                <th data-label="Shopify" scope="row">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-combobox_container">
                                                                                                <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                                    {!v.Country_Code}
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </th>
                                                                                <th data-label="Salesforce" scope="row">
                                                                                    
                                                                                    <lightning:select aura:id="AccountCountryCodeField" class="Country_Code" name="select1" label="Choose Field" onchange="{!c.Customer_Country_Code}">
                                                                                        <option value="{!v.testcountryfield}" text="{!v.testcountryfield}" /> 
                                                                                        <aura:iteration items="{!v.Salesforcefields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                        </aura:iteration> 
                                                                                    </lightning:select> 
                                                                                </th>
                                                                            </tr>
                                                                            
                                                                            <tr class="slds-hint-parent">
                                                                                <th data-label="Shopify" scope="row">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-combobox_container">
                                                                                                <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                                    {!v.Billing_State}
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </th>
                                                                                <th data-label="Salesforce" scope="row">
                                                                                    <lightning:select aura:id="AccountCountryCodeField" class="Country_Code" name="select1" label="Choose Field" onchange="{!c.Customer_Billing_State}">
                                                                                        <option value="{!v.MapBilling_State}" text="{!v.MapBilling_State}" /> 
                                                                                      	 <aura:iteration items="{!v.Salesforcefields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                        </aura:iteration> 
                                                                                    </lightning:select> 
                                                                                </th>  
                                                                            </tr> 
                                                                            <tr class="slds-hint-parent">
                                                                                <th data-label="Shopify" scope="row">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-combobox_container">
                                                                                                <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                                    {!v.Billing_Country}
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </th>
                                                                                <th data-label="Salesforce" scope="row">
                                                                                    <lightning:select aura:id="AccountCountryCodeField" class="Country_Code" name="select1" label="Choose Field" onchange="{!c.Customer_Billing_Country}">
                                                                                        <option value="{!v.MapBilling_Country}" text="{!v.MapBilling_Country}" /> 
                                                                                        	<aura:iteration items="{!v.Salesforcefields}" var="per">
                                                                                            	<option value="{!per}" text="{!per}" /> 
                                                                                            </aura:iteration> 
                                                                                    </lightning:select> 
                                                                                </th>  
                                                                            </tr> 
                                                                            
                                                                            <tr>
                                                                                <th data-label="Shopify" scope="row">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-combobox_container">
                                                                                                <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                                    {!v.Email}
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </th>
                                                                                <th data-label="Salesforce" scope="row">
                                                                                    <lightning:select aura:id="SalesforceField" class="" name="select1" label="Choose Field" onchange="{!c.Customer_Email}">
                                                                                        <option value="TechnologyMind__Shopify_Email__c" text="Shopify_Email" /> 
                                                                                          <aura:iteration items="{!v.Salesforcefields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                       	 </aura:iteration>
                                                                                    </lightning:select>
                                                                                </th>
                                                                            </tr>
                                                                            <tr>
                                                                                <th data-label="Shopify" scope="row">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-combobox_container">
                                                                                                <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                                    {!v.Customer_id}
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </th>
                                                                                <th data-label="Salesforce" scope="row">
                                                                                    <lightning:select aura:id="SalesforceField" class="" name="select1" label="Choose Field" onchange="{!c.Customer_Customer_id}">
                                                                                        <option value="TechnologyMind__Shopify_Customer_Id__c" text="Shopify_Customer_Id" /> 
                                                                                          <aura:iteration items="{!v.Salesforcefields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                        </aura:iteration> 
                                                                                    </lightning:select>
                                                                                </th>
                                                                            </tr>
                                                                            
                                                                            <tr>
                                                                                <th data-label="Shopify" scope="row">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-combobox_container">
                                                                                                <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                                    {!v.First_Name}
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </th>
                                                                                <th data-label="Salesforce" scope="row">
                                                                                    <lightning:select aura:id="SalesforceField" class="" name="select1" label="Choose Field" onchange="{!c.Customer_First_Name}">
                                                                                        <option value="Name" text="Name" /> 
                                                                                        <aura:iteration items="{!v.Salesforcefields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                        </aura:iteration> 
                                                                                    </lightning:select>
                                                                                </th>
                                                                            </tr>
                                                                            <tr>
                                                                                <th data-label="Shopify" scope="row">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-combobox_container">
                                                                                                <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                                    {!v.Last_Name}
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </th>
                                                                                <th data-label="Salesforce" scope="row">
                                                                                    <lightning:select aura:id="SalesforceField" class="" name="select1" label="Choose Field" onchange="{!c.Customer_Last_Name}">
                                                                                        <option value="{!v.MapLast_Name}" text="{!v.MapLast_Name}" /> 
                                                                                        <aura:iteration items="{!v.Salesforcefields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                        </aura:iteration>
                                                                                    </lightning:select>
                                                                                </th>
                                                                            </tr>
                                                                            <tr>
                                                                                <th data-label="Shopify" scope="row">
                                                                                    <div class="slds-form-element">
                                                                                        <div class="slds-form-element__control">
                                                                                            <div class="slds-combobox_container">
                                                                                                <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                                    {!v.Last_Order_Name}
                                                                                                </div>
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
