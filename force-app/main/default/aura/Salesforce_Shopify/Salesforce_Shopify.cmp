<aura:component controller="Configuration" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    <aura:attribute name="selectedStep" type="string" default="step1"/>
     <aura:attribute name="ProductDataType" type="String" default="Shopify"/>
     <aura:attribute name="deleteProductid" type="String"/> 
    <aura:attribute name="EditselectedStep" type="string" default="step1"/>
    <aura:attribute name="options" type="List" default="[{'label':'Standard','value':'OptionOne'},{'label':'Standard Price Book','value':'OptionTwo'},{'label':'Option Three','value':'OptionThree'}]" />
    <aura:attribute name="productscount" type="Integer"/>
    <aura:attribute name="customerscount" type="Integer"/>
    <aura:attribute name="orderscount" type="Integer"/>
    <aura:attribute name="Shopname" type="String"/>
    <aura:attribute name="PageNumber" type="integer" default="1"/> 
    <aura:attribute name="Allshopid" type="list" />
    <aura:attribute name="TotalPages" type="integer" default="0"/>
    <aura:attribute name="TotalRecords" type="integer" default="0"/>
    <aura:attribute name="RecordStart" type="integer" default="0"/>
    <aura:attribute name="RecordEnd" type="integer" default="0"/>
    <aura:attribute name="pageSize" type="integer" default="5"/>
    <aura:attribute name="isOpen" type="boolean" default="false"/>
    <aura:attribute name="isEdit" type="boolean" default="false"/>
    <aura:attribute name="Productlist" type="list" />
    <aura:attribute name="Orderlist" type="list" />
    <aura:attribute name="Customerlist" type="list" />
    
    <aura:attribute name="Shopid" type="String"/>
    <aura:attribute name="searchKeyword" type="String"/>
    <aura:attribute name="Shoplist" type="list" />
    <aura:attribute name="Shopifyfields" type="list" />
    <aura:attribute name="Salesforcefields" type="list" /> 
    <!--new-->
    <aura:attribute name="SalesforceStringfields" type="list" />
    <aura:attribute name="SalesforceNumberfields" type="list" />
   <aura:attribute name="SalesforcePhonefields" type="list" />
     <aura:attribute name="SalesforceEmailfields" type="list" />
    <!--new-->
    <aura:attribute name="ShopifyCustomerFields" type="list" />
    <aura:attribute name="Productfields" type="list" />
    <aura:attribute name="ProductStringFields" type="list" />
    <aura:attribute name="ProductNumberFields" type="list" />
<aura:attribute name="ProductPhoneFields" type="list" />
    <aura:attribute name="ProductEmailFields" type="list" />
        
    <aura:attribute name="SelectedCustomerField" type="String" default="None" /> 
    <aura:attribute name="Selectedfields" type="String" default="None" /> 
    <aura:attribute name="SelectedOrderField" type="String" default="None" /> 
    <aura:attribute name="OrderFields" type="list" />
      <aura:attribute name="OrderStringFields" type="list" />
     <aura:attribute name="OrderEmailFields" type="list" />
     <aura:attribute name="OrderPhoneFields" type="list" />
    
    <aura:attribute name="OrderNumberFields" type="list" />
    <aura:attribute name="messageshow" type="String" default="slds-hide"/>
    <aura:attribute name="defaultApp" type="String"/>
    
    
      <aura:attribute name="NewShopName" type="String"/>
     <aura:attribute name="ShopToken" type="String"/>
     <aura:attribute name="ShopPasswords" type="String"/>
    
    <aura:attribute name="Customermapfields" type="Map" />
    
    <aura:attribute name="mapping" type="list" />
    <aura:attribute name="Productmapping" type="list" />
    <aura:attribute name="Ordermapping" type="list" />
    
    <aura:attribute name="Salesforcemapping" type="list" />
    <aura:attribute name="Shopifymapping" type="list" />
    
    <aura:attribute name="productSalesforceMapping" type="list" />
    <aura:attribute name="productShopifyMapping" type="list" />
    
    <aura:attribute name="OrderSalesforceMapping" type="list" />
    <aura:attribute name="OrderShopifyMapping" type="list" />
    
    <aura:attribute name="messageType" type="String"/>
    <aura:attribute name="message" type="String"/>
    <aura:attribute name="newShopify" type="Object"/>
    <aura:attribute name="newShopifyError" type="String"/>
    <aura:attribute name="simpleNewShopify" type="Object"/>
    <!-- Edit button Attributes -->
    <aura:attribute name="EditShopURL" type="String"/>
    <aura:attribute name="EditAccessToken" type="String"/>
    <aura:attribute name="EditPassword" type="String"/>
    
    <!-- Customer Mapping Attributes -->
    <aura:attribute name="Country_Code" type="String" Default="Country_Code"/>
    <aura:attribute name="testcountryfield" type="String" /> 
    <aura:attribute name="Created_at" type="String" Default="Created_at"/>
    <aura:attribute name="MapCreated_at" type="String" />
    <aura:attribute name="Customer_id" type="String" Default="Customer_id"/>
    <aura:attribute name="MapCustomer_id" type="String" />
    <aura:attribute name="First_Name" type="String" Default="First_Name"/>
    <aura:attribute name="MapFirst_Name" type="String" />
    <aura:attribute name="Last_Name" type="String" Default="Last_Name"/>
    <aura:attribute name="MapLast_Name" type="String" />
    <aura:attribute name="Last_Order_Name" type="String" Default="Last_Order_Name"/>
    <aura:attribute name="MapLast_Order_Name" type="String" />
    <aura:attribute name="Customer_Orders_Count" type="String" Default="Orders_Count"/>
    <aura:attribute name="MapCustomer_Orders_Count" type="String" />
    <aura:attribute name="Phone" type="String" Default="Phone"/>
    <aura:attribute name="MapPhone" type="String" />
    <aura:attribute name="Province_Code" type="String" Default="Province_Code"/>
    <aura:attribute name="MapProvince_Code" type="String" />
    <aura:attribute name="Total_Spent" type="String" Default="Total_Spent"/>
    <aura:attribute name="MapTotal_Spent" type="String" />
    <aura:attribute name="Updated_at" type="String" Default="Updated_at"/>
    <aura:attribute name="MapUpdated_at" type="String" />
    <aura:attribute name="Zip" type="String" Default="Zip"/>
    <aura:attribute name="MapZip" type="String" />
    <aura:attribute name="Email" type="String" Default="Email"/>   
    <aura:attribute name="MapEmail" type="String" />
    <aura:attribute name="Billing_State" type="String" Default="Billing_State"/> 
    <aura:attribute name="MapBilling_State" type="String" />
    <aura:attribute name="Billing_Country" type="String" Default="Billing_Country"/>
    <aura:attribute name="MapBilling_Country" type="String" />
    
    
    <!-- Product Mapping Attributes -->
     <aura:attribute name="Productmapfields" type="Map" />
    <aura:attribute name="Title" type="String" Default="Title"/>
    <aura:attribute name="MapTitle" type="String" />
    <aura:attribute name="Product_type" type="String" Default="Product_type"/>
    <aura:attribute name="MapProduct_type" type="String" />
    <aura:attribute name="Vendor" type="String" Default="Vendor"/>
    <aura:attribute name="MapVendor" type="String" />
    <aura:attribute name="Handle" type="String" Default="Handle"/>
    <aura:attribute name="MapHandle" type="String" />
    <aura:attribute name="Product_Id" type="String" Default="Product_Id"/>
    <aura:attribute name="MapProduct_Id" type="String" />
    <aura:attribute name="Image_Src" type="String" Default="Image_Src"/>
    <aura:attribute name="MapImage_Src" type="String" />
    <aura:attribute name="Variants_price" type="String" Default="Variants_price"/>
    <aura:attribute name="MapVariants_price" type="String" />
    <aura:attribute name="Tags" type="String" Default="Tags"/>
    <aura:attribute name="MapTags" type="String" />
    
    <!-- Order Mapping Attributes -->
     <aura:attribute name="Ordermapfields" type="Map" />
    <aura:attribute name="Address1" type="String" Default="Address1"/>
    <aura:attribute name="MapAddress1" type="String" />
    <aura:attribute name="Address2" type="String" Default="Address2"/>
    <aura:attribute name="MapAddress2" type="String" />
    <aura:attribute name="City" type="String" Default="City"/>
    <aura:attribute name="MapCity" type="String" />
    <aura:attribute name="Contact_Email" type="String" Default="Contact_Email"/>
    <aura:attribute name="MapContact_Email" type="String" />
    <aura:attribute name="Country" type="String" Default="Country"/>
    <aura:attribute name="MapCountry" type="String" />
    <aura:attribute name="Order_Customer_id" type="String" Default="Customer_id"/>
    <aura:attribute name="MapOrder_Customer_id" type="String" />
    <aura:attribute name="Order_First_Name" type="String" Default="First_Name"/>
    <aura:attribute name="MapOrder_First_Name" type="String" />
    <aura:attribute name="Order_Last_Name" type="String" Default="Last_Name"/>
    <aura:attribute name="MapOrder_Last_Name" type="String" />
    <aura:attribute name="Last_Order_id" type="String" Default="Last_Order_id"/>
    <aura:attribute name="MapLast_Order_id" type="String" />
    <aura:attribute name="Order_Name" type="String" Default="Order_Name"/>
    <aura:attribute name="MapOrder_Name" type="String" />
    <aura:attribute name="Orders_Count" type="String" Default="Orders_Count"/>
    <aura:attribute name="MapOrders_Count" type="String" />
    <aura:attribute name="Total_Price" type="String" Default="Total_Price"/>
    <aura:attribute name="MapTotal_Price" type="String" />
    <aura:attribute name="Order_ID" type="String" Default="Shopify_Order_ID"/>
    <aura:attribute name="MapOrder_ID" type="String" />
    
    <force:recordData aura:id="shopifyRecordCreator"
                      layoutType="FULL"
                      targetRecord="{!v.newShopify}"
                      targetFields="{!v.simpleNewShopify}"
                      fields="Name,TechnologyMind__Salesforce_Site_URL__c,TechnologyMind__Shopify_Access_Token__c,TechnologyMind__Password__c"
                      targetError="{!v.newShopifyError}"
                      mode="New"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    
    
    <lightning:tabset variant="scoped"> 
       <!-- <lightning:tab id="-LplUSA3_QCrN3hTByRM">
            <aura:set attribute="label">
                <lightning:icon iconName="utility:settings" size="small"></lightning:icon>Configuration</aura:set>  -->
        <lightning:tab >
        <div class="slds-container_fluid">
                <div class="slds-media slds-p-around_x-small slds-p-top_x-small slds-p-right_x-small slds-p-bottom_x-small slds-p-left_x-small">
                    <div class="slds-media__figure">
                        <lightning:avatar alternativeText="" fallbackIconName="utility:setup" size="slds-avatar_medium" src="" variant="square"></lightning:avatar>
                    </div>
                    <div class="slds-media__body">
                        <div class="slds-text-heading_medium" contenteditable="false">Configuration</div>
                        <div class="ABC"  contenteditable="false"><b>Total Records : </b>{!v.TotalRecords} </div>
                    </div>
                    <div class="slds-media__figure slds-media__figure_reverse"></div>
                </div>
            </div>
            <div class="slds-input-has-icon_left">
                <lightning:button class="slds-button slds-button_success slds-float_right" iconPosition="left" variant="neutral" label="Add Shop" iconName="utility:Add" onclick="{!c.openModel}"></lightning:button>
                <br/>
                <!-- <lightning:buttonIcon alternativeText="" iconClass="" class="slds-float_right slds-theme_default slds-card slds-card_boundary" onclick="{!c.openModel}" variant="bare" type="button" iconName="utility:add" size="large"></lightning:buttonIcon>-->
                
                <!--Use aura:if tag to display Model Box, on the bese of conditions. [isOpen boolean attribute] -->   
                <aura:if isTrue="{!v.isOpen}">
                    
                    <!--###### MODAL BOX Start######--> 
                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                        <div class="slds-modal__container" >
                            <!-- ###### MODAL BOX HEADER Start ######-->
                            <header class="slds-modal__header">
                                <lightning:buttonIcon iconName="utility:close"
                                                      onclick="{! c.closeModel }"
                                                      alternativeText="close"
                                                      variant="bare-inverse"
                                                      class="slds-modal__close"/>
                                <h2 id="modal-heading-01" class="slds-text-heading_medium slds-hyphenate"><b>Configuration</b></h2>
                            </header>
                            <!--###### MODAL BOX BODY Part Start######-->
                            <div class="slds-card">
                                <div class="slds-m-around_xx-large">
                                    <c:MessageComponent type="{!v.messageType}" message="{!v.message}" class="{!v.messageshow}"/>
                                    <lightning:progressIndicator currentStep="{!v.selectedStep}" type="path">
                                        
                                        <lightning:progressStep label="General" value="step1" onclick="{!c.EditselectStep1}"/>
                                        <lightning:progressStep label="Object Setting" value="step2" onclick="{!c.EditselectStep2}"/>
                                        <lightning:progressStep label="Customer Filed Mapping" value="step4" onclick="{!c.EditselectStep4}"/>
                                        <lightning:progressStep label="Product Filed Mapping" value="step5" onclick="{!c.EditselectStep5}"/>
                                        <lightning:progressStep label="Order Filed Mapping" value="step6" onclick="{!c.EditselectStep6}"/>
                                        
                                    </lightning:progressIndicator>
                                    <div class="slds-p-around--medium ">
                                        <div class="{!v.selectedStep == 'step1' ? 'slds-show' : 'slds-hide'}">
                                            <div class="slds-scrollable_y" > 
                                                <div class="inputdiv">                         
                                                     <lightning:input aura:id="Url" name="Name" label="Shopify Shop URL" value="{!v.simpleNewShopify.Name}" required="true"/>
                                                    <!--  <lightning:input name="Salesforce Site URL" label="Salesforce Site URL" value="{!v.simpleNewShopify.Salesforce_Site_URL__c}" required="true"/> -->
                                                    <lightning:input aura:id="AccessToken" name="access Token" label="Shopify Access Token" value="{!v.simpleNewShopify.TechnologyMind__Shopify_Access_Token__c}" required="true"/>
                                                    <!-- <lightning:combobox label="" options="{!v.options}" placeholder="Salesforce Pricebook " dropdownAlignment="left" variant="standard"></lightning:combobox> -->
                                                    <lightning:input aura:id="AppPassword" type="password" name="Shopify App Password" label="Shopify App Password" value="{!v.simpleNewShopify.TechnologyMind__Password__c}" required="true"/>
                                                    <br/>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="{!v.selectedStep == 'step2' ? 'slds-show' : 'slds-hide'}">
                                            <div class="slds-scrollable_y" > 
                                                <p><b>Step 2</b></p>
                                                <table cellspacing="0" rules="all" border="1" id="Table1" style="border-collapse: collapse;">
                                                    <tr>
                                                        <th class="slds-text-heading_medium slds-p-around_xx-small ABD" ><center>Shopify</center></th>
                                                        <th class="slds-text-heading_medium slds-p-around_xx-small ABE" ><center>Salesforce</center></th>
                                                    </tr>
                                                    <tr>
                                                        <td><center>Product</center></td>
                                                        <!--xx-small, x-small, small, medium, or large  -->
                                                        <td><div class="slds-p-around_x-small slds-text-align_center"> <lightning:icon iconName="action:approval" alternativeText="Approved" size="xx-small" /> &nbsp;Mapped as Product</div></td>
                                                    </tr>
                                                    <tr>
                                                        <td><center>Customer</center></td>
                                                        <td><div class="slds-p-around_x-small slds-text-align_center"> <lightning:icon iconName="action:approval" alternativeText="Approved" size="xx-small" /> &nbsp;Mapped as Account</div></td>
                                                    </tr>
                                                    <tr>
                                                        <td><center>Order</center></td>
                                                        <td><div class="slds-p-around_x-small slds-text-align_center"> <lightning:icon iconName="action:approval" alternativeText="Approved" size="xx-small" /> &nbsp;Mapped as ShopifyOrders</div></td>
                                                    </tr>
                                                </table>
                                                <br />
                                            </div>
                                        </div>
                                        <div class="{!v.selectedStep == 'step4' ? 'slds-show' : 'slds-hide'}">
                                            <p><b>Step 3</b></p>
                                            <div class="slds-scrollable_y" >
                                                <h1><center><b>Customer Field Mapping</b></center></h1>
                                                <table class="slds-table slds-table_cell-buffer slds-table_bordered slds-table_col-bordered ABF" >
                                                    <thead>
                                                        <tr class="slds-line-height_reset">
                                                            <th class="" scope="col">
                                                                <div class="slds-truncate" title="Shopify" >Shopify</div>
                                                            </th>
                                                            <th class="" scope="col">
                                                                <div class="slds-truncate" title="Salesforce">Salesforce</div>
                                                            </th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr class="slds-hint-parent">
                                                            <th data-label="Shopify" scope="row">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <div class="slds-combobox_container">
                                                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                {!v.Country_Code}
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </th>
                                                            <th data-label="Salesforce" scope="row">
                                                                <lightning:select aura:id="AccountCountryCodeField" class="Country_Code" name="select1" label="Choose Field" onchange="{!c.Customer_Country_Code}">
                                                                    <option value="None" text="None" /> 
                                                                    <aura:iteration items="{!v.SalesforceStringfields}" var="per">
                                                                        <option value="{!per}" text="{!per}" /> 
                                                                    </aura:iteration>
                                                                </lightning:select> 
                                                            </th>
                                                        </tr>
                                                        
                                                        <tr class="slds-hint-parent">
                                                            <th data-label="Shopify" scope="row">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <div class="slds-combobox_container">
                                                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                {!v.Billing_State}
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </th>
                                                            <th data-label="Salesforce" scope="row">
                                                                <lightning:select aura:id="AccountCountryCodeField" class="Country_Code" name="select1" label="Choose Field" onchange="{!c.Customer_Billing_State}"> >
                                                                    <option value="None" text="None" /> 
                                                                    <aura:iteration items="{!v.SalesforceStringfields}" var="per">
                                                                        <option value="{!per}" text="{!per}" /> 
                                                                    </aura:iteration>
                                                                </lightning:select> 
                                                            </th>  
                                                        </tr> 
                                                        <tr class="slds-hint-parent">
                                                            <th data-label="Shopify" scope="row">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <div class="slds-combobox_container">
                                                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                {!v.Billing_Country}
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </th>
                                                            <th data-label="Salesforce" scope="row">
                                                                <lightning:select aura:id="AccountCountryCodeField" class="Country_Code" name="select1" label="Choose Field" onchange="{!c.Customer_Billing_Country}">
                                                                    <option value="None" text="None" /> 
                                                                    <aura:iteration items="{!v.SalesforceStringfields}" var="per">
                                                                        <option value="{!per}" text="{!per}" /> 
                                                                    </aura:iteration>
                                                                </lightning:select> 
                                                            </th>  
                                                        </tr> 
                                                        
                                                        <tr>
                                                            <th data-label="Shopify" scope="row">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <div class="slds-combobox_container">
                                                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                {!v.Email}
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </th>
                                                            <th data-label="Salesforce" scope="row">
                                                                <lightning:select aura:id="SalesforceField" class="" name="select1" label="Choose Field" onchange="{!c.Customer_Email}">
                                                                 <!--   <option value="Shopify_Email__c" text="Shopify_Email" />  -->
                                                                      <aura:iteration items="{!v.SalesforceEmailfields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                        </aura:iteration>
                                                                </lightning:select>
                                                            </th>
                                                        </tr>
                                                        <tr>
                                                            <th data-label="Shopify" scope="row">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <div class="slds-combobox_container">
                                                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                {!v.Customer_id}
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </th>
                                                            <th data-label="Salesforce" scope="row">
                                                                <lightning:select aura:id="SalesforceField" class="" name="select1" label="Choose Field" onchange="{!c.Customer_Customer_id}">
                                                                    <option value="TechnologyMind__Shopify_Customer_Id__c" text="Shopify_Customer_Id" /> 
                                                                    <!--  <aura:iteration items="{!v.SalesforceStringfields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                        </aura:iteration> -->
                                                                </lightning:select>
                                                            </th>
                                                        </tr>
                                                        
                                                        <tr>
                                                            <th data-label="Shopify" scope="row">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <div class="slds-combobox_container">
                                                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                {!v.First_Name}
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </th>
                                                            <th data-label="Salesforce" scope="row">
                                                                <lightning:select aura:id="SalesforceField" class="" name="select1" label="Choose Field" onchange="{!c.Customer_First_Name}">
                                                                    <option value="Name" text="Name" /> 
                                                                    <!--  <aura:iteration items="{!v.SalesforceStringfields}" var="per">
                                                                                            <option value="{!per}" text="{!per}" /> 
                                                                                        </aura:iteration> -->
                                                                </lightning:select>
                                                            </th>
                                                        </tr>
                                                        <tr>
                                                            <th data-label="Shopify" scope="row">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <div class="slds-combobox_container">
                                                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                {!v.Last_Name}
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </th>
                                                            <th data-label="Salesforce" scope="row">
                                                                <lightning:select aura:id="SalesforceField" class="" name="select1" label="Choose Field" onchange="{!c.Customer_Last_Name}">
                                                                    <option value="None" text="None" /> 
                                                                    <aura:iteration items="{!v.SalesforceStringfields}" var="per">
                                                                        <option value="{!per}" text="{!per}" /> 
                                                                    </aura:iteration>
                                                                </lightning:select>
                                                            </th>
                                                        </tr>
                                                        <tr>
                                                            <th data-label="Shopify" scope="row">
                                                                <div class="slds-form-element">
                                                                    <div class="slds-form-element__control">
                                                                        <div class="slds-combobox_container">
                                                                            <div class="slds-combobox slds-dropdown-trigger slds-dropdown-trigger_click" aria-expanded="false" aria-haspopup="listbox" role="combobox">
                                                                                {!v.Last_Order_Name}
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
